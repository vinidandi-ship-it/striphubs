# StripHubs Environment Variables

# ==========================================

# REQUIRED - Primary API Configuration
# -------------------------------
STRIPCASH_API_KEY=your_stripcash_api_key_here
VITE_SITE_URL=https://your-domain.com

# REQUIRED - Affiliate Tracking
# ----------------------------
AFFILIATE_ID=your_affiliate_id_here
VITE_AFFILIATE_ID=your_affiliate_id_here

# OPTIONAL - API Endpoints
# ------------------------
STRIPCHAT_API_ENDPOINT=https://go.mavrtracktor.com/api/models
VITE_MODELS_ENDPOINT=https://go.mavrtracktor.com/api/models

# OPTIONAL - Statistics & Admin
# -----------------------------
STRIPCASH_STATS_API_KEY=your_stats_api_key_here
ADMIN_KEY=your_admin_secret_key_here

# OPTIONAL - Postback Configuration
# -------------------------------
POSTBACK_TOKEN=your_postback_token_here
POSTBACK_SECRET=your_hmac_secret_here

# OPTIONAL - Provider Configuration
# -------------------------------
ENABLE_CHATURBATE=true

# OPTIONAL - Stripe (Premium Checkout)
# -------------------------------
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
